# =====================================
# 钢琴助手后端环境配置
# =====================================

# 应用配置
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# MySQL 配置 (用于关系型数据: 用户、练习记录)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=piano_assistant

# MongoDB 配置 (用于文档型数据: 乐理知识、文章)
MONGODB_URI=mongodb://localhost:27017/piano_assistant

# 可选: Redis 配置 (用于缓存)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# 可选: 文件存储配置
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=piano-files
